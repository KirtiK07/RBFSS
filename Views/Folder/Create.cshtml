@model CreateFolderDto
@{
    ViewData["Title"] = "Create Folder";
    var parentFolder = ViewBag.ParentFolder as RBFSS.Models.Folder;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    📁 New Folder
                    @if (parentFolder != null)
                    {
                        <small class="text-muted fw-normal">inside @parentFolder.FolderName</small>
                    }
                    else
                    {
                        <small class="text-muted fw-normal">at root</small>
                    }
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="ParentFolderId" />

                    <div class="mb-3">
                        <label asp-for="FolderName" class="form-label fw-semibold">Folder Name <span class="text-danger">*</span></label>
                        <input asp-for="FolderName" class="form-control" placeholder="e.g. Project Documents" autofocus />
                        <span asp-validation-for="FolderName" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create Folder</button>
                        <a asp-action="Index" asp-route-folderId="@Model.ParentFolderId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
