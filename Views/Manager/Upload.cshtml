@model FileUploadDto
@{
    ViewData["Title"] = "Upload File";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">Upload File</h3>
            </div>
            <div class="card-body">
                @if (ViewData.ModelState.Count > 0)
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="File" class="form-label">Select File</label>
                        <input asp-for="File" class="form-control" type="file" required>
                        <span asp-validation-for="File" class="text-danger"></span>
                        <div class="form-text">
                            Allowed types: PDF, DOC, DOCX, TXT, JPG, PNG, GIF. Max size: 10MB
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description (Optional)</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter a description for this file..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="ShareWithAllUsers" class="form-check-input" type="checkbox">
                            <label asp-for="ShareWithAllUsers" class="form-check-label">
                                Share with all users
                            </label>
                        </div>
                        <div class="form-text">If checked, all users in the system will be able to access this file.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Save to Folder (optional)</label>
                        <select name="FolderId" class="form-select">
                            <option value="">— Root (no folder) —</option>
                            @foreach (var folder in (ViewBag.Folders as IEnumerable<RBFSS.Models.Folder> ?? new List<RBFSS.Models.Folder>()))
                            {
                                <option value="@folder.FolderId">@folder.FolderName</option>
                            }
                        </select>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Upload File</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-4">
            <div class="alert alert-info">
                <h6>File Sharing Rules:</h6>
                <ul class="mb-0">
                    <li><strong>Managers</strong> can upload files and share them with users</li>
                    <li>Files are automatically accessible by other managers</li>
                    <li>Users can only see files explicitly shared with them</li>
                    <li>Admins can see all files in the system</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}